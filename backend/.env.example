# ============================================================
# FarmWise Backend – Environment Variables
# ============================================================
# 1. Copy this file to ".env":  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit the ".env" file — it is in .gitignore
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ── Groq AI ──────────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
# Keys look like: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=your_groq_api_key_here

# ── MongoDB Atlas (Cloud) ─────────────────────────────────────
# Step 1: Create a free cluster at https://cloud.mongodb.com
# Step 2: Click "Connect" → "Drivers" → copy the URI below
# Step 3: Replace <username>, <password>, and <cluster-url>
#
# FORMAT:
#   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# EXAMPLE (Atlas):
#   mongodb+srv://farmwise_user:MySecret123@cluster0.abcde.mongodb.net/farmwise?retryWrites=true&w=majority
#
# LOCAL fallback (for offline development):
#   mongodb://localhost:27017/farmwise
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/farmwise?retryWrites=true&w=majority

# ── JWT (Authentication) ──────────────────────────────────────
# Use a long, random string — minimum 32 characters
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d             # Token expiry: 1h | 7d | 30d

# ── CORS / Frontend URL ───────────────────────────────────────
# This tells the backend which frontend origin to allow.
FRONTEND_URL=http://localhost:3000

# ── (Frontend) Vite Environment Variables ─────────────────────
# NOTE: These belong in frontend/.env, NOT here.
#       They are listed for reference only so devs know what the
#       frontend needs. VITE_ variables are NEVER read by Node.js.
#
# VITE_API_BASE_URL=http://localhost:5000
