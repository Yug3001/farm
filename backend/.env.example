# ============================================================
# FarmWise Backend – Environment Variables
# ============================================================
# 1. Copy this file to ".env":  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit the ".env" file — it is in .gitignore
# ============================================================

# Server
PORT=5000

# Google Gemini AI
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB (use Atlas URI for cloud deployment, local URI for development)
# LOCAL  → mongodb://localhost:27017/farmwise
# ATLAS  → mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@clusterX.xxxxx.mongodb.net/farmwise?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/farmwise

# JWT Secret — use a long random string (min 32 chars)
JWT_SECRET=replace_with_a_strong_random_secret_string

# Frontend URL (used for CORS)
VITE_API_BASE_URL=http://localhost:3000
